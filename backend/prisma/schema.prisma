datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  PATIENT
  DOCTOR
  ADMIN
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
}

// --- ENTITIES ---
model Hospital {
  id        String   @id @default(uuid())
  name      String
  users     User[]   
  createdAt DateTime @default(now())
}

model User {
  id            String   @id @default(uuid())
  email         String?   @unique
  phoneNumber   String?   @unique
  password      String?   
  isAppRegistered Boolean @default(false)
  name          String
  role          Role     @default(PATIENT)
  
  hospitalId    String?
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")

  createdAt     DateTime @default(now())
}

model PatientProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dominantDosha String?  
  vataScore     Int?
  pittaScore    Int?
  kaphaScore    Int?
  
  age           Int?
  gender        String?
  bloodGroup    String?

  prakriti      String?
  vikriti       String?

  allergies     String[] @default([])
  dietaryPref   String?
  
  clinicalData  Json?    
}

model DoctorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specialty     String   
  experienceYrs Int?
  isAvailable   Boolean  @default(true)
  departmentId  String?
  department  Department? @relation(fields: [departmentId], references: [id])
}

model Appointment {
  id              String   @id @default(uuid())
  
  patientId       String
  patient         User     @relation("PatientAppointments", fields: [patientId], references: [id])
  doctorId        String
  doctor          User     @relation("DoctorAppointments", fields: [doctorId], references: [id])
  
  scheduledAt     DateTime
  status          AppointmentStatus @default(SCHEDULED)
  
  patientSymptoms String?  @db.Text 
  aiSummary       String?  @db.Text 

  doctorNotes     String?  @db.Text // Private notes the doctor writes during the call
  
  dietChart       Json?    // Stores the meal timings, foods, and dosha rules
  routinePlan     Json?    // Stores the Asanas/Yoga and lifestyle instructions
  medications     Json?    // Stores the Ayurvedic medicines, dosage, and timing
  
  // Track if the appointment is done
  isCompleted     Boolean  @default(false)

  paymentStatus PaymentStatus @default(PENDING)
  transactionId String? @unique

  rescheduledToId String? @unique
  rescheduledTo Appointment? @relation("RescheduleHistory",fields: [rescheduledToId], references: [id])
  rescheduledFrom Appointment? @relation("RescheduleHistory")
  
  createdAt       DateTime @default(now())
}

model Department {
  id          String          @id @default(uuid())
  name        String          @unique 
  description String          @db.Text 
  
  doctors     DoctorProfile[] // A department can have many doctors
  
  createdAt   DateTime        @default(now())
}